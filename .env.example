SECRET_KEY=change-me-use-a-long-random-string
DEBUG=False

POSTGRES_DB=portal
POSTGRES_USER=portal
POSTGRES_PASSWORD=change-me

# Bind mount path on the Pi host for media files (e.g. /mnt/nas/photos)
MEDIA_PATH=./app/media

# Initial admin user — only used if no admin user exists at startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Reddit API — create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pi-lab-portal/1.0 (by u/your_username)
